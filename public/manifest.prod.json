{
  "manifest_version": 3,
  "name": "Local Video Lab",
  "short_name": "Local Video Lab",
  "version": "0.0.1",
  "description": "ローカル動画をブラウザ上で快適に閲覧するためのユーティリティビューア",
  "icons": {
    "48": "icons/icon.png"
  },
  "permissions": ["storage"],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://*/*", "http://*/*"],
      "js": ["content.js"]
    }
  ]
}
